---
import Layout from '../layouts/Layout.astro';

const neighborhoods = [
  {
    name: 'Manitou Springs',
    tagline: 'Walk to the Incline, Cliff Dwellings, and Manitou Avenue.',
    vibe: 'Historic, walkable, mineral-spring charm.',
  },
  {
    name: 'Old Colorado City',
    tagline: 'Boutiques, breweries, and a quick drive to Garden of the Gods.',
    vibe: 'Historic main street with an artsy streak.',
  },
  {
    name: 'Downtown Colorado Springs',
    tagline: 'Tejon Street restaurants, the Olympic Museum, and nightlife at your door.',
    vibe: 'Central, urban, and perfect for first-time visitors.',
  },
  {
    name: 'Broadmoor / Cheyenne Cañon',
    tagline: 'Minutes from Seven Falls, Helen Hunt Falls, and The Broadmoor.',
    vibe: 'Quiet, leafy, resort-adjacent.',
  },
  {
    name: 'North Side',
    tagline: 'Easy access to hiking at Ute Valley and the Air Force Academy gate.',
    vibe: 'Newer, family-friendly, close to outdoor trails.',
  },
];
---
<Layout
  title="Where to Stay in Colorado Springs"
  description="Find the best neighborhoods and vacation rentals in Colorado Springs — curated picks with our recommended property manager, Nestago."
>
  <section class="relative overflow-hidden bg-gradient-to-b from-mountain-900 via-mountain-800 to-forest-700">
    <div class="absolute inset-0 opacity-20" aria-hidden="true">
      <svg viewBox="0 0 1200 400" preserveAspectRatio="none" class="h-full w-full">
        <path d="M0 320 L180 180 L280 240 L420 120 L560 220 L720 100 L880 220 L1040 140 L1200 240 L1200 400 L0 400 Z" fill="#547840"/>
        <path d="M0 360 L120 260 L260 320 L380 240 L520 300 L660 220 L800 300 L960 260 L1100 320 L1200 300 L1200 400 L0 400 Z" fill="#334a28" opacity="0.8"/>
      </svg>
    </div>
    <div class="container-page relative py-20 sm:py-24 lg:py-28">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-clay-300">Where to stay</p>
      <h1 class="mt-4 max-w-3xl font-display text-4xl font-semibold leading-tight text-white sm:text-5xl">
        A home base for your Colorado Springs adventure.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-sand-100/90">
        Pick your neighborhood, then pick your place. We partner with a local property manager who
        knows these streets — and takes care of every guest like a neighbor.
      </p>
    </div>
  </section>

  <section class="container-page py-16 sm:py-20">
    <div class="overflow-hidden rounded-3xl border border-mountain-100 bg-white shadow-card">
      <div class="grid gap-0 lg:grid-cols-[1.2fr_1fr]">
        <div class="p-8 sm:p-12">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-clay-600">Our recommended partner</p>
          <h2 class="mt-3 font-display text-3xl font-semibold sm:text-4xl">Nestago</h2>
          <p class="mt-4 text-lg leading-relaxed text-mountain-700">
            Nestago is a Colorado Springs-based vacation rental management company. Every property
            is owner-cared-for and guest-tested — thoughtfully furnished, professionally cleaned,
            and supported by a local team that actually picks up the phone.
          </p>
          <ul class="mt-6 space-y-3 text-sm text-mountain-700">
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-lg">🏔️</span>
              <span>Homes across Manitou Springs, Old Colorado City, Downtown, and the foothills.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-lg">🔑</span>
              <span>Self-check-in and 24/7 local support.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-lg">🧺</span>
              <span>Professional cleaning, fresh linens, fully stocked kitchens.</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-0.5 text-lg">📍</span>
              <span>Curated guest guides — including this one — for every stay.</span>
            </li>
          </ul>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://www.nestago.com"
              target="_blank"
              rel="noopener"
              class="btn-primary"
            >
              Browse Nestago rentals
            </a>
            <a
              href="https://www.nestago.com"
              target="_blank"
              rel="noopener"
              class="btn-secondary"
            >
              nestago.com
            </a>
          </div>
        </div>
        <div class="relative min-h-[280px] bg-gradient-to-br from-forest-700 via-forest-700 to-mountain-800 lg:min-h-0">
          <div class="absolute inset-0 flex items-center justify-center p-10">
            <div class="text-center text-white">
              <p class="font-display text-5xl font-semibold leading-tight sm:text-6xl">Nestago</p>
              <p class="mt-3 text-sm uppercase tracking-[0.2em] text-sand-100/80">
                Colorado Springs vacation rentals
              </p>
              <p class="mt-6 text-sand-100/90">Stay local. Stay well hosted.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page pb-20">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="font-display text-3xl font-semibold sm:text-4xl">Pick your neighborhood</h2>
        <p class="mt-2 text-mountain-600">Each one has its own rhythm — here's how to choose.</p>
      </div>
    </div>
    <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {neighborhoods.map((n) => (
        <article class="rounded-2xl border border-mountain-100 bg-white p-6 shadow-card">
          <h3 class="font-display text-xl font-semibold">{n.name}</h3>
          <p class="mt-2 text-sm text-mountain-700">{n.tagline}</p>
          <p class="mt-3 text-xs uppercase tracking-[0.15em] text-mountain-500">{n.vibe}</p>
        </article>
      ))}
    </div>

    <div class="mt-12 rounded-2xl bg-sand-100 p-8 text-center">
      <p class="font-display text-xl text-mountain-800">Not sure which neighborhood fits?</p>
      <p class="mt-2 text-mountain-600">
        Tell Nestago what you're here to do — they'll match you to the right home.
      </p>
      <a
        href="https://www.nestago.com"
        target="_blank"
        rel="noopener"
        class="mt-5 inline-flex btn-primary"
      >
        Find your stay on Nestago
      </a>
    </div>
  </section>
</Layout>
