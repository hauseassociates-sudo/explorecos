---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ListingCard from '../../components/ListingCard.astro';
import { CATEGORIES, CATEGORY_META } from '../../content/config';

export async function getStaticPaths() {
  return CATEGORIES.map((slug) => ({ params: { category: slug } }));
}

const { category } = Astro.params;
const slug = category as (typeof CATEGORIES)[number];
const meta = CATEGORY_META[slug];

const allListings = await getCollection('listings');
const listings = allListings
  .filter((l) => l.data.category === slug)
  .sort((a, b) => {
    if (a.data.lloydsPick !== b.data.lloydsPick) return a.data.lloydsPick ? -1 : 1;
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return a.data.name.localeCompare(b.data.name);
  });

// --- Build filter chips dynamically based on what this category actually has.
const lloydsCount = listings.filter((l) => l.data.lloydsPick).length;
const featuredCount = listings.filter((l) => l.data.featured && !l.data.lloydsPick).length;

const PRICE_ORDER = ['Free', '$', '$$', '$$$', '$$$$'] as const;
type Price = (typeof PRICE_ORDER)[number];
const priceCounts = PRICE_ORDER.reduce<Record<string, number>>((acc, p) => {
  acc[p] = listings.filter((l) => l.data.priceRange === p).length;
  return acc;
}, {});
const priceChips = PRICE_ORDER.filter((p) => priceCounts[p] > 0);

// --- Map points (just this category)
const points = listings.map((entry) => ({
  slug: entry.slug,
  name: entry.data.name,
  lat: entry.data.coordinates.lat,
  lng: entry.data.coordinates.lng,
  lloydsPick: entry.data.lloydsPick ?? false,
  photo: entry.data.photos[0] ?? null,
}));

const categoryColors: Record<(typeof CATEGORIES)[number], string> = {
  'hiking-trails': '#547840',
  'restaurants-food': '#c67b4a',
  'attractions': '#1e3a5f',
  'shopping': '#b35f2b',
  'nightlife': '#334e68',
  'family-activities': '#3f5e30',
  'parks': '#6f9459',
  'museums': '#486581',
  'day-trips': '#793b25',
};
const pinColor = categoryColors[slug];
---
<Layout title={`${meta.title} in Colorado Springs`} description={meta.tagline}>
  {points.length > 0 && (
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
  )}

  <section class="border-b border-mountain-100 bg-gradient-to-b from-sand-100 to-sand-50">
    <div class="container-page py-12 sm:py-16">
      <nav class="text-xs font-medium text-mountain-500" aria-label="Breadcrumb">
        <a href="/" class="hover:text-mountain-800">Home</a>
        <span class="px-1.5">/</span>
        <span class="text-mountain-700">{meta.title}</span>
      </nav>
      <div class="mt-4 flex flex-wrap items-center gap-3">
        <span class="text-4xl sm:text-5xl" aria-hidden="true">{meta.emoji}</span>
        <h1 class="font-display text-3xl font-semibold sm:text-5xl">{meta.title}</h1>
      </div>
      <p class="mt-3 max-w-2xl text-lg text-mountain-700">{meta.tagline}</p>
      <p class="mt-2 text-sm text-mountain-500">
        <span data-listing-count>{listings.length}</span> of {listings.length} {listings.length === 1 ? 'place' : 'places'}
      </p>
    </div>
  </section>

  {points.length > 0 && (
    <section class="container-page pt-8 sm:pt-10">
      <div
        id={`category-map-${slug}`}
        class="h-[280px] w-full overflow-hidden rounded-2xl border border-mountain-100 shadow-card sm:h-[340px]"
        role="application"
        aria-label={`Map of ${meta.title} in Colorado Springs`}
        data-category-map
      ></div>
    </section>
  )}

  {(lloydsCount > 0 || featuredCount > 0 || priceChips.length > 0) && (
    <section class="container-page pt-6">
      <div class="flex flex-wrap items-center gap-2" data-category-filters>
        <span class="mr-1 text-xs font-semibold uppercase tracking-[0.15em] text-mountain-500">
          Filter:
        </span>
        {lloydsCount > 0 && (
          <button
            type="button"
            class="map-chip"
            data-filter-type="lloydsPick"
            data-filter-value="true"
            aria-pressed="false"
          >
            <span aria-hidden="true">⭐</span>
            <span>Lloyd's Picks</span>
            <span class="map-chip-count">{lloydsCount}</span>
          </button>
        )}
        {featuredCount > 0 && (
          <button
            type="button"
            class="map-chip"
            data-filter-type="featured"
            data-filter-value="true"
            aria-pressed="false"
          >
            <span aria-hidden="true">✨</span>
            <span>Guest favorites</span>
            <span class="map-chip-count">{featuredCount}</span>
          </button>
        )}
        {priceChips.map((p) => (
          <button
            type="button"
            class="map-chip"
            data-filter-type="price"
            data-filter-value={p}
            aria-pressed="false"
          >
            <span>{p}</span>
            <span class="map-chip-count">{priceCounts[p]}</span>
          </button>
        ))}
        <button
          type="button"
          class="ml-auto text-xs font-semibold text-mountain-500 underline-offset-2 hover:text-mountain-800 hover:underline"
          data-filter-clear
          hidden
        >
          Clear filters
        </button>
      </div>
    </section>
  )}

  <section class="container-page py-8 sm:py-10">
    {listings.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-mountain-200 bg-white p-10 text-center">
        <p class="font-display text-xl text-mountain-700">More spots coming soon.</p>
        <p class="mt-2 text-sm text-mountain-500">We're out scouting right now — check back shortly.</p>
      </div>
    ) : (
      <>
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" data-listings-grid>
          {listings.map((entry) => (
            <div
              data-listing
              data-slug={entry.slug}
              data-lloyds-pick={String(entry.data.lloydsPick ?? false)}
              data-featured={String(entry.data.featured ?? false)}
              data-price={entry.data.priceRange ?? ''}
            >
              <ListingCard entry={entry} />
            </div>
          ))}
        </div>
        <div
          class="mt-10 hidden rounded-2xl border border-dashed border-mountain-200 bg-white p-8 text-center"
          data-empty-state
        >
          <p class="font-display text-lg text-mountain-700">No spots match those filters.</p>
          <p class="mt-1 text-sm text-mountain-500">Try removing one to see more.</p>
        </div>
      </>
    )}
  </section>

  {points.length > 0 && (
    <>
      <script
        src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""
        is:inline
      ></script>

      <script
        is:inline
        define:vars={{ points, pinColor, mapId: `category-map-${slug}` }}
      >
        function whenReady(cb) {
          if (typeof window.L !== 'undefined') return cb();
          const interval = setInterval(() => {
            if (typeof window.L !== 'undefined') {
              clearInterval(interval);
              cb();
            }
          }, 30);
        }

        whenReady(() => {
          const L = window.L;
          const map = L.map(mapId, {
            scrollWheelZoom: false,
            zoomControl: true,
          });

          L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
          }).addTo(map);

          function pinIcon(point) {
            const isPick = !!point.lloydsPick;
            const ring = isPick ? '#c67b4a' : '#ffffff';
            const ringWidth = isPick ? 3 : 2;
            const size = isPick ? 32 : 26;
            const star = isPick
              ? '<text x="50%" y="56%" text-anchor="middle" font-size="14" fill="#fff" font-family="system-ui">★</text>'
              : '';
            const html = `
              <svg width="${size}" height="${size}" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="15" cy="15" r="${13 - ringWidth / 2}" fill="${pinColor}" stroke="${ring}" stroke-width="${ringWidth}"/>
                ${star}
              </svg>
            `;
            return L.divIcon({
              className: 'cos-pin',
              html,
              iconSize: [size, size],
              iconAnchor: [size / 2, size / 2],
              popupAnchor: [0, -size / 2 + 2],
            });
          }

          function escapeHtml(s) {
            return String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
          }

          const markers = points.map((point) => {
            const m = L.marker([point.lat, point.lng], { icon: pinIcon(point) });
            const photo = point.photo
              ? `<img src="${escapeHtml(point.photo)}" class="cos-popup-photo" alt="" loading="lazy"/>`
              : '';
            const pick = point.lloydsPick
              ? '<span class="cos-popup-pick">★ Lloyd\u2019s Pick</span>'
              : '';
            m.bindPopup(
              `<div class="cos-popup">
                ${photo}
                <div class="cos-popup-body">
                  <div class="cos-popup-name">${escapeHtml(point.name)}</div>
                  <div class="cos-popup-meta">${pick}</div>
                  <a class="cos-popup-link" href="/listings/${escapeHtml(point.slug)}">View details &rarr;</a>
                </div>
              </div>`,
              { maxWidth: 240, minWidth: 200 }
            );
            return m;
          });

          markers.forEach((m) => m.addTo(map));

          if (markers.length === 1) {
            map.setView(markers[0].getLatLng(), 13);
          } else {
            const bounds = L.latLngBounds(markers.map((m) => m.getLatLng()));
            map.fitBounds(bounds, { padding: [30, 30], maxZoom: 14 });
          }

          setTimeout(() => map.invalidateSize(), 100);
        });
      </script>
    </>
  )}

  <script is:inline>
    // --- Filter chip behavior ---
    const filterBar = document.querySelector('[data-category-filters]');
    const grid = document.querySelector('[data-listings-grid]');
    const emptyState = document.querySelector('[data-empty-state]');
    const visibleCount = document.querySelector('[data-listing-count]');
    const clearBtn = document.querySelector('[data-filter-clear]');

    if (filterBar && grid) {
      const cards = Array.from(grid.querySelectorAll('[data-listing]'));
      const buttons = Array.from(filterBar.querySelectorAll('button[data-filter-type]'));
      // Active filters: { lloydsPick: bool, featured: bool, prices: Set }
      const active = { lloydsPick: false, featured: false, prices: new Set() };

      function applyFilters() {
        let visible = 0;
        cards.forEach((card) => {
          const lloyds = card.getAttribute('data-lloyds-pick') === 'true';
          const featured = card.getAttribute('data-featured') === 'true';
          const price = card.getAttribute('data-price') || '';

          let show = true;
          if (active.lloydsPick && !lloyds) show = false;
          if (active.featured && !featured) show = false;
          if (active.prices.size > 0 && !active.prices.has(price)) show = false;

          card.style.display = show ? '' : 'none';
          if (show) visible += 1;
        });
        if (visibleCount) visibleCount.textContent = String(visible);
        if (emptyState) {
          if (visible === 0) emptyState.classList.remove('hidden');
          else emptyState.classList.add('hidden');
        }
        if (clearBtn) {
          const anyActive = active.lloydsPick || active.featured || active.prices.size > 0;
          clearBtn.hidden = !anyActive;
        }
      }

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const type = btn.getAttribute('data-filter-type');
          const value = btn.getAttribute('data-filter-value');
          if (type === 'lloydsPick' || type === 'featured') {
            active[type] = !active[type];
            btn.classList.toggle('is-active', active[type]);
            btn.setAttribute('aria-pressed', String(active[type]));
          } else if (type === 'price' && value) {
            if (active.prices.has(value)) {
              active.prices.delete(value);
              btn.classList.remove('is-active');
              btn.setAttribute('aria-pressed', 'false');
            } else {
              active.prices.add(value);
              btn.classList.add('is-active');
              btn.setAttribute('aria-pressed', 'true');
            }
          }
          applyFilters();
        });
      });

      clearBtn?.addEventListener('click', () => {
        active.lloydsPick = false;
        active.featured = false;
        active.prices.clear();
        buttons.forEach((b) => {
          b.classList.remove('is-active');
          b.setAttribute('aria-pressed', 'false');
        });
        applyFilters();
      });
    }
  </script>

  <style is:global>
    /* Filter chips — same look as /map page */
    .map-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 0.85rem;
      border-radius: 9999px;
      border: 1px solid #d9e2ec;
      background: #ffffff;
      color: #334e68;
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    }
    .map-chip:hover {
      border-color: #bcccdc;
      background: #f5ebd8;
    }
    .map-chip.is-active {
      background: #1e3a5f;
      border-color: #1e3a5f;
      color: #ffffff;
    }
    .map-chip-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.4rem;
      padding: 0 0.35rem;
      height: 1.25rem;
      border-radius: 9999px;
      background: rgba(30, 58, 95, 0.08);
      color: inherit;
      font-size: 0.7rem;
      font-weight: 600;
    }
    .map-chip.is-active .map-chip-count {
      background: rgba(255, 255, 255, 0.18);
    }
    .cos-pin { background: transparent !important; border: none !important; }
    .leaflet-popup-content-wrapper { border-radius: 14px; padding: 0; overflow: hidden; }
    .leaflet-popup-content { margin: 0 !important; width: auto !important; }
    .cos-popup { width: 220px; font-family: 'Inter', system-ui, sans-serif; }
    .cos-popup-photo { width: 100%; height: 110px; object-fit: cover; display: block; }
    .cos-popup-body { padding: 10px 12px 12px; }
    .cos-popup-name { font-family: 'Fraunces', Georgia, serif; font-size: 1rem; font-weight: 600; color: #1e3a5f; line-height: 1.25; }
    .cos-popup-meta { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 6px; }
    .cos-popup-meta:empty { display: none; }
    .cos-popup-pick { display: inline-flex; align-items: center; gap: 3px; background: #c67b4a; color: #fff; font-size: 0.7rem; font-weight: 600; padding: 2px 8px; border-radius: 9999px; }
    .cos-popup-link { display: inline-block; margin-top: 8px; font-size: 0.85rem; font-weight: 600; color: #547840; text-decoration: none; }
    .cos-popup-link:hover { color: #334a28; text-decoration: underline; }
  </style>
</Layout>
