---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { CATEGORY_META } from '../content/config';

const allListings = await getCollection('listings');

// Default sort (used when geolocation isn't available): Lloyd's Picks first,
// then featured, then alphabetical. The client-side script re-sorts by distance
// once geolocation succeeds.
const sorted = allListings.sort((a, b) => {
  if (a.data.lloydsPick !== b.data.lloydsPick) return a.data.lloydsPick ? -1 : 1;
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return a.data.name.localeCompare(b.data.name);
});

// Light-weight payload for the client-side distance calculation.
const points = allListings.map((entry) => ({
  slug: entry.slug,
  lat: entry.data.coordinates.lat,
  lng: entry.data.coordinates.lng,
}));
---
<Layout
  title="Near Me"
  description="Find Colorado Springs spots closest to you — sorted by distance using your phone's location."
>
  <section class="border-b border-mountain-100 bg-gradient-to-b from-sand-100 to-sand-50">
    <div class="container-page py-10 sm:py-12">
      <nav class="text-xs font-medium text-mountain-500" aria-label="Breadcrumb">
        <a href="/" class="hover:text-mountain-800">Home</a>
        <span class="px-1.5">/</span>
        <span class="text-mountain-700">Near Me</span>
      </nav>
      <div class="mt-3 flex items-center gap-3">
        <span class="text-4xl sm:text-5xl" aria-hidden="true">📍</span>
        <h1 class="font-display text-3xl font-semibold sm:text-5xl">Near Me</h1>
      </div>
      <p class="mt-3 max-w-2xl text-mountain-700">
        Tap the button below to find ExploreCOS picks closest to where you are right now.
        Your location stays in your browser — we don't send it anywhere.
      </p>
    </div>
  </section>

  <section class="container-page py-6">
    <div
      class="rounded-2xl border border-mountain-100 bg-white p-5 shadow-card sm:p-6"
      data-near-banner
      data-state="initial"
    >
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div class="flex items-center gap-3">
          <span class="text-2xl" aria-hidden="true" data-banner-icon>📍</span>
          <div>
            <p class="font-display text-lg font-semibold text-mountain-900" data-banner-title>
              Find spots near you
            </p>
            <p class="text-sm text-mountain-600" data-banner-subtitle>
              We'll sort all {allListings.length} listings by distance from your location.
            </p>
          </div>
        </div>
        <button
          type="button"
          class="btn-primary"
          data-request-location
        >
          Allow location access
        </button>
      </div>
    </div>
  </section>

  <section class="container-page pb-16">
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3" data-listing-grid>
      {sorted.map((entry) => {
        const { name, category, address, description, photos, priceRange, lloydsPick } = entry.data;
        const cover = photos[0] ?? null;
        const catMeta = CATEGORY_META[category];
        return (
          <a
            href={`/listings/${entry.slug}`}
            class="group flex flex-col overflow-hidden rounded-2xl border border-mountain-100 bg-white shadow-card transition hover:-translate-y-0.5 hover:shadow-card-hover"
            data-near-card
            data-slug={entry.slug}
            data-lat={entry.data.coordinates.lat}
            data-lng={entry.data.coordinates.lng}
          >
            <div class="relative aspect-[4/3] w-full overflow-hidden bg-sand-100">
              {cover ? (
                <img
                  src={cover}
                  alt={name}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-4xl">
                  {catMeta.emoji}
                </div>
              )}
              <span class="absolute left-3 top-3 chip bg-white/90 backdrop-blur">
                <span>{catMeta.emoji}</span>
                <span>{catMeta.title}</span>
              </span>
              {lloydsPick && (
                <span class="absolute right-3 top-3 inline-flex items-center gap-1 rounded-full bg-clay-500 px-2.5 py-1 text-xs font-semibold text-white shadow-sm">
                  <span aria-hidden="true">⭐</span>
                  <span>Lloyd's Pick</span>
                </span>
              )}
              <span
                class="absolute left-3 bottom-3 hidden items-center gap-1 rounded-full bg-mountain-900/90 px-2.5 py-1 text-xs font-semibold text-white shadow-sm backdrop-blur"
                data-distance-pill
              >
                <span aria-hidden="true">📍</span>
                <span data-distance-text></span>
              </span>
            </div>
            <div class="flex flex-1 flex-col gap-2 p-5">
              <div class="flex items-start justify-between gap-3">
                <h3 class="font-display text-lg font-semibold leading-tight text-mountain-900 group-hover:text-forest-700">
                  {name}
                </h3>
                {priceRange && (
                  <span class="shrink-0 text-sm font-medium text-mountain-500">{priceRange}</span>
                )}
              </div>
              <p class="text-xs text-mountain-500">{address}</p>
              <p class="line-clamp-2 text-sm text-mountain-700">{description}</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <script is:inline define:vars={{ points }}>
    const banner = document.querySelector('[data-near-banner]');
    const requestBtn = document.querySelector('[data-request-location]');
    const grid = document.querySelector('[data-listing-grid]');
    const cards = Array.from(document.querySelectorAll('[data-near-card]'));

    function setBanner(state, title, subtitle, icon) {
      if (!banner) return;
      banner.setAttribute('data-state', state);
      const titleEl = banner.querySelector('[data-banner-title]');
      const subtitleEl = banner.querySelector('[data-banner-subtitle]');
      const iconEl = banner.querySelector('[data-banner-icon]');
      if (titleEl) titleEl.textContent = title;
      if (subtitleEl) subtitleEl.textContent = subtitle;
      if (iconEl && icon) iconEl.textContent = icon;
    }

    // Haversine — accurate enough for our purposes (rough miles).
    function distanceMiles(lat1, lng1, lat2, lng2) {
      const R = 3958.8; // Earth radius in miles
      const toRad = (d) => (d * Math.PI) / 180;
      const dLat = toRad(lat2 - lat1);
      const dLng = toRad(lng2 - lng1);
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLng / 2) ** 2;
      return 2 * R * Math.asin(Math.sqrt(a));
    }

    function formatDistance(miles) {
      if (miles < 0.1) return 'right here';
      if (miles < 1) return `${(miles * 5280).toFixed(0)} ft`;
      if (miles < 10) return `${miles.toFixed(1)} mi`;
      return `${Math.round(miles)} mi`;
    }

    function applyDistances(userLat, userLng) {
      const byDistance = points
        .map((p) => ({
          ...p,
          d: distanceMiles(userLat, userLng, p.lat, p.lng),
        }))
        .sort((a, b) => a.d - b.d);

      // Update each card with its distance
      cards.forEach((card) => {
        const slug = card.getAttribute('data-slug');
        const match = byDistance.find((p) => p.slug === slug);
        if (!match) return;
        const pill = card.querySelector('[data-distance-pill]');
        const text = card.querySelector('[data-distance-text]');
        if (text) text.textContent = formatDistance(match.d);
        if (pill) {
          pill.classList.remove('hidden');
          pill.classList.add('inline-flex');
        }
      });

      // Re-order DOM by distance
      const slugOrder = byDistance.map((p) => p.slug);
      const ordered = slugOrder
        .map((slug) => cards.find((c) => c.getAttribute('data-slug') === slug))
        .filter(Boolean);
      ordered.forEach((card) => grid.appendChild(card));

      const closest = byDistance[0];
      setBanner(
        'ready',
        `${cards.length} spots, sorted by distance`,
        `Closest: ${formatDistance(closest.d)} away.`,
        '✨'
      );
      if (requestBtn) {
        requestBtn.textContent = 'Update location';
      }
    }

    function requestLocation() {
      if (!('geolocation' in navigator)) {
        setBanner(
          'unsupported',
          'Geolocation not supported',
          "Your browser doesn't support location access. Showing all spots in our default order.",
          '⚠️'
        );
        return;
      }
      setBanner('loading', 'Finding spots near you…', 'Asking your browser for location.', '📡');
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          applyDistances(pos.coords.latitude, pos.coords.longitude);
        },
        (err) => {
          let msg = "We couldn't read your location. Showing all spots in our default order.";
          if (err && err.code === err.PERMISSION_DENIED) {
            msg = 'Location access denied. You can change this in your browser settings.';
          }
          setBanner('denied', 'No problem — here are all our picks', msg, '🌄');
          if (requestBtn) requestBtn.textContent = 'Try again';
        },
        { enableHighAccuracy: false, timeout: 10000, maximumAge: 60000 }
      );
    }

    requestBtn?.addEventListener('click', requestLocation);
  </script>
</Layout>
