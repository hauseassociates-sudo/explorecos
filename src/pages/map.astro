---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { CATEGORIES, CATEGORY_META } from '../content/config';

const allListings = await getCollection('listings');

// Trim down to just what the client needs to plot markers / show popups.
const points = allListings.map((entry) => ({
  slug: entry.slug,
  name: entry.data.name,
  category: entry.data.category,
  address: entry.data.address,
  lat: entry.data.coordinates.lat,
  lng: entry.data.coordinates.lng,
  photo: entry.data.photos[0] ?? null,
  priceRange: entry.data.priceRange ?? null,
  lloydsPick: entry.data.lloydsPick ?? false,
  featured: entry.data.featured ?? false,
}));

const countsByCategory = Object.fromEntries(
  CATEGORIES.map((slug) => [slug, points.filter((p) => p.category === slug).length])
) as Record<(typeof CATEGORIES)[number], number>;

// Center on Colorado Springs — roughly Acacia Park.
const defaultCenter = { lat: 38.8339, lng: -104.8214 };
---
<Layout
  title="Map of Colorado Springs"
  description="Every ExploreCOS recommendation on one interactive map — filter by category and tap a pin for details."
>
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <section class="border-b border-mountain-100 bg-gradient-to-b from-sand-100 to-sand-50">
    <div class="container-page py-10 sm:py-12">
      <nav class="text-xs font-medium text-mountain-500" aria-label="Breadcrumb">
        <a href="/" class="hover:text-mountain-800">Home</a>
        <span class="px-1.5">/</span>
        <span class="text-mountain-700">Map</span>
      </nav>
      <div class="mt-3 flex flex-wrap items-end justify-between gap-4">
        <div>
          <div class="flex items-center gap-3">
            <span class="text-4xl sm:text-5xl" aria-hidden="true">🗺️</span>
            <h1 class="font-display text-3xl font-semibold sm:text-5xl">Map of Colorado Springs</h1>
          </div>
          <p class="mt-3 max-w-2xl text-mountain-700">
            Every place we'd send a friend, all on one map. Tap any pin for the full story —
            and use the filters to focus on what you're in the mood for.
          </p>
        </div>
        <p class="text-sm text-mountain-500">
          <span data-visible-count>{points.length}</span> of {points.length} places shown
        </p>
      </div>
    </div>
  </section>

  <section class="container-page py-6">
    <div
      class="flex flex-wrap items-center gap-2"
      role="group"
      aria-label="Filter by category"
      data-category-filters
    >
      <button
        type="button"
        class="map-chip is-active"
        data-filter="all"
        aria-pressed="true"
      >
        <span aria-hidden="true">✨</span>
        <span>All</span>
        <span class="map-chip-count">{points.length}</span>
      </button>
      {CATEGORIES.map((slug) => (
        <button
          type="button"
          class="map-chip"
          data-filter={slug}
          aria-pressed="false"
        >
          <span aria-hidden="true">{CATEGORY_META[slug].emoji}</span>
          <span>{CATEGORY_META[slug].title}</span>
          <span class="map-chip-count">{countsByCategory[slug]}</span>
        </button>
      ))}
    </div>
  </section>

  <section class="container-page pb-16">
    <div
      id="cos-map"
      class="h-[70vh] min-h-[480px] w-full overflow-hidden rounded-3xl border border-mountain-100 shadow-card"
      role="application"
      aria-label="Interactive map of Colorado Springs places"
    ></div>
    <p class="mt-3 text-xs text-mountain-500">
      Map data © <a href="https://www.openstreetmap.org/copyright" target="_blank" rel="noopener" class="underline hover:text-mountain-800">OpenStreetMap</a> contributors.
      Pins drop on a curated mix of {points.length} ExploreCOS recommendations.
    </p>
  </section>

  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline
  ></script>

  <script
    is:inline
    define:vars={{
      points,
      defaultCenter,
      categoryMeta: CATEGORY_META,
    }}
  >
    // Wait for Leaflet to be ready (the script above is loaded async).
    function whenReady(cb) {
      if (typeof window.L !== 'undefined') return cb();
      const interval = setInterval(() => {
        if (typeof window.L !== 'undefined') {
          clearInterval(interval);
          cb();
        }
      }, 30);
    }

    whenReady(() => {
      const L = window.L;

      // Map setup — start zoomed to fit Colorado Springs metro.
      const map = L.map('cos-map', {
        center: [defaultCenter.lat, defaultCenter.lng],
        zoom: 11,
        scrollWheelZoom: true,
      });

      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      }).addTo(map);

      // Color per category — borrowed from the palette so it feels native.
      const categoryColors = {
        'hiking-trails':     '#547840', // forest-500
        'restaurants-food':  '#c67b4a', // clay-500
        'attractions':       '#1e3a5f', // mountain-900
        'shopping':          '#b35f2b', // clay-600
        'nightlife':         '#334e68', // mountain-700
        'family-activities': '#3f5e30', // forest-600
        'parks':             '#6f9459', // forest-400
        'museums':           '#486581', // mountain-600
        'day-trips':         '#793b25', // clay-800
      };

      const fallbackColor = '#486581';

      function pinIcon(point) {
        const color = categoryColors[point.category] || fallbackColor;
        const isPick = !!point.lloydsPick;
        const ring = isPick ? '#c67b4a' : '#ffffff';
        const ringWidth = isPick ? 3 : 2;
        const size = isPick ? 36 : 30;
        const star = isPick
          ? '<text x="50%" y="56%" text-anchor="middle" font-size="14" fill="#fff" font-family="system-ui">★</text>'
          : '';
        const html = `
          <svg width="${size}" height="${size}" viewBox="0 0 30 30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="15" cy="15" r="${13 - ringWidth / 2}" fill="${color}" stroke="${ring}" stroke-width="${ringWidth}"/>
            ${star}
          </svg>
        `;
        return L.divIcon({
          className: 'cos-pin' + (isPick ? ' cos-pin--pick' : ''),
          html,
          iconSize: [size, size],
          iconAnchor: [size / 2, size / 2],
          popupAnchor: [0, -size / 2 + 2],
        });
      }

      function popupHtml(point) {
        const meta = categoryMeta[point.category] || { title: point.category, emoji: '📍' };
        const photo = point.photo
          ? `<img src="${point.photo}" alt="" class="cos-popup-photo" loading="lazy"/>`
          : '';
        const pick = point.lloydsPick
          ? '<span class="cos-popup-pick">★ Lloyd\u2019s Pick</span>'
          : '';
        const price = point.priceRange
          ? `<span class="cos-popup-price">${point.priceRange}</span>`
          : '';
        return `
          <div class="cos-popup">
            ${photo}
            <div class="cos-popup-body">
              <div class="cos-popup-cat">${meta.emoji} ${meta.title}</div>
              <div class="cos-popup-name">${point.name}</div>
              <div class="cos-popup-meta">${pick}${price}</div>
              <div class="cos-popup-address">${point.address}</div>
              <a class="cos-popup-link" href="/listings/${point.slug}">View details &rarr;</a>
            </div>
          </div>
        `;
      }

      // Build all markers up front, keep them in a flat array so we can show/hide.
      const markers = points.map((point) => {
        const m = L.marker([point.lat, point.lng], { icon: pinIcon(point) });
        m.bindPopup(popupHtml(point), { maxWidth: 280, minWidth: 220 });
        m._cosCategory = point.category;
        return m;
      });

      const layer = L.layerGroup(markers).addTo(map);

      // Fit map to all markers initially so nothing is off-screen.
      if (markers.length > 0) {
        const bounds = L.latLngBounds(markers.map((m) => m.getLatLng()));
        map.fitBounds(bounds, { padding: [40, 40] });
      }

      // Category filter wiring.
      const filterBar = document.querySelector('[data-category-filters]');
      const visibleCount = document.querySelector('[data-visible-count]');
      let activeFilter = 'all';

      function applyFilter(slug) {
        activeFilter = slug;
        let visible = 0;
        markers.forEach((m) => {
          const show = slug === 'all' || m._cosCategory === slug;
          if (show) {
            if (!layer.hasLayer(m)) layer.addLayer(m);
            visible += 1;
          } else if (layer.hasLayer(m)) {
            layer.removeLayer(m);
          }
        });
        if (visibleCount) visibleCount.textContent = String(visible);

        // If we're filtered to a category and have any markers, fit to those.
        if (slug !== 'all') {
          const shown = markers.filter((m) => m._cosCategory === slug);
          if (shown.length > 0) {
            const b = L.latLngBounds(shown.map((m) => m.getLatLng()));
            map.fitBounds(b, { padding: [40, 40], maxZoom: 14 });
          }
        }
      }

      filterBar?.querySelectorAll('button[data-filter]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const slug = btn.getAttribute('data-filter');
          if (!slug || slug === activeFilter) return;
          filterBar.querySelectorAll('button[data-filter]').forEach((b) => {
            const isActive = b === btn;
            b.classList.toggle('is-active', isActive);
            b.setAttribute('aria-pressed', String(isActive));
          });
          applyFilter(slug);
        });
      });

      // Re-flow when the page becomes visible (e.g. after route change in dev).
      setTimeout(() => map.invalidateSize(), 100);
    });
  </script>

  <style is:global>
    /* Filter chips */
    .map-chip {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 0.85rem;
      border-radius: 9999px;
      border: 1px solid #d9e2ec; /* mountain-100 */
      background: #ffffff;
      color: #334e68; /* mountain-700 */
      font-size: 0.85rem;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    }
    .map-chip:hover {
      border-color: #bcccdc;
      background: #f5ebd8; /* sand-100 */
    }
    .map-chip.is-active {
      background: #1e3a5f; /* mountain-900 */
      border-color: #1e3a5f;
      color: #ffffff;
    }
    .map-chip-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 1.4rem;
      padding: 0 0.35rem;
      height: 1.25rem;
      border-radius: 9999px;
      background: rgba(30, 58, 95, 0.08);
      color: inherit;
      font-size: 0.7rem;
      font-weight: 600;
    }
    .map-chip.is-active .map-chip-count {
      background: rgba(255, 255, 255, 0.18);
    }

    /* Custom Leaflet pin reset */
    .cos-pin {
      background: transparent !important;
      border: none !important;
    }

    /* Popup styling — override Leaflet defaults to feel on-brand */
    .leaflet-popup-content-wrapper {
      border-radius: 16px;
      box-shadow: 0 10px 30px rgba(30, 58, 95, 0.18);
      padding: 0;
      overflow: hidden;
    }
    .leaflet-popup-content {
      margin: 0 !important;
      width: auto !important;
    }
    .leaflet-popup-tip {
      box-shadow: 0 6px 12px rgba(30, 58, 95, 0.15);
    }
    .cos-popup {
      width: 240px;
      font-family: 'Inter', system-ui, sans-serif;
    }
    .cos-popup-photo {
      width: 100%;
      height: 130px;
      object-fit: cover;
      display: block;
    }
    .cos-popup-body {
      padding: 12px 14px 14px;
    }
    .cos-popup-cat {
      font-size: 0.7rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #627d98;
      font-weight: 600;
    }
    .cos-popup-name {
      margin-top: 2px;
      font-family: 'Fraunces', Georgia, serif;
      font-size: 1.05rem;
      font-weight: 600;
      color: #1e3a5f;
      line-height: 1.25;
    }
    .cos-popup-meta {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 6px;
    }
    .cos-popup-pick {
      display: inline-flex;
      align-items: center;
      gap: 3px;
      background: #c67b4a;
      color: #fff;
      font-size: 0.7rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 9999px;
    }
    .cos-popup-price {
      display: inline-flex;
      align-items: center;
      background: #f5ebd8;
      color: #334e68;
      font-size: 0.7rem;
      font-weight: 600;
      padding: 2px 8px;
      border-radius: 9999px;
    }
    .cos-popup-address {
      margin-top: 8px;
      font-size: 0.78rem;
      color: #627d98;
      line-height: 1.4;
    }
    .cos-popup-link {
      display: inline-block;
      margin-top: 10px;
      font-size: 0.85rem;
      font-weight: 600;
      color: #547840;
      text-decoration: none;
    }
    .cos-popup-link:hover {
      color: #334a28;
      text-decoration: underline;
    }
  </style>
</Layout>
