---
import Logo from './Logo.astro';
import { CATEGORIES, CATEGORY_META } from '../content/config';

const navItems = CATEGORIES.map((slug) => ({
  slug,
  title: CATEGORY_META[slug].title,
}));
---
<header class="sticky top-0 z-40 border-b border-mountain-100 bg-sand-50/90 backdrop-blur">
  <div class="container-page flex h-16 items-center justify-between gap-4">
    <Logo />
    <nav class="hidden lg:block" aria-label="Primary">
      <ul class="flex items-center gap-1 text-sm font-medium text-mountain-700">
        {navItems.slice(0, 5).map((item) => (
          <li>
            <a
              href={`/categories/${item.slug}`}
              class="rounded-full px-3 py-2 transition hover:bg-mountain-100 hover:text-mountain-900"
            >
              {item.title}
            </a>
          </li>
        ))}
        <li>
          <a
            href="/map"
            class="rounded-full px-3 py-2 transition hover:bg-mountain-100 hover:text-mountain-900"
          >
            Map
          </a>
        </li>
        <li>
          <a
            href="/near-me"
            class="rounded-full px-3 py-2 transition hover:bg-mountain-100 hover:text-mountain-900"
          >
            Near Me
          </a>
        </li>
      </ul>
    </nav>
    <div class="flex items-center gap-2">
      <a href="/stay" class="hidden sm:inline-flex btn-primary">Find a stay</a>
      <button
        type="button"
        class="lg:hidden inline-flex items-center justify-center rounded-full border border-mountain-200 bg-white p-2 text-mountain-700"
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-mobile-toggle
      >
        <span class="sr-only">Open menu</span>
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden lg:hidden border-t border-mountain-100 bg-white">
    <ul class="container-page grid grid-cols-2 gap-1 py-3 text-sm font-medium text-mountain-700">
      {navItems.map((item) => (
        <li>
          <a
            href={`/categories/${item.slug}`}
            class="block rounded-lg px-3 py-2 hover:bg-sand-100 hover:text-mountain-900"
          >
            {item.title}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/map"
          class="block rounded-lg px-3 py-2 hover:bg-sand-100 hover:text-mountain-900"
        >
          Map
        </a>
      </li>
      <li>
        <a
          href="/near-me"
          class="block rounded-lg px-3 py-2 hover:bg-sand-100 hover:text-mountain-900"
        >
          Near Me
        </a>
      </li>
      <li>
        <a
          href="/stay"
          class="block rounded-lg px-3 py-2 hover:bg-sand-100 hover:text-mountain-900"
        >
          Where to Stay
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector('[data-mobile-toggle]');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
</script>
