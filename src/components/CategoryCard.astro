---
import { CATEGORY_META } from '../content/config';
interface Props {
  slug: keyof typeof CATEGORY_META;
  count?: number;
}
const { slug, count } = Astro.props;
const meta = CATEGORY_META[slug];
---
<a
  href={`/categories/${slug}`}
  class="group relative flex flex-col justify-between overflow-hidden rounded-2xl border border-mountain-100 bg-white p-5 shadow-card transition hover:-translate-y-0.5 hover:border-forest-200 hover:shadow-card-hover"
>
  <div class="text-3xl">{meta.emoji}</div>
  <div class="mt-6">
    <h3 class="font-display text-lg font-semibold text-mountain-900 group-hover:text-forest-700">
      {meta.title}
    </h3>
    <p class="mt-1 text-sm text-mountain-600">{meta.tagline}</p>
    {count !== undefined && (
      <p class="mt-3 text-xs font-medium uppercase tracking-wider text-clay-600">
        {count} {count === 1 ? 'spot' : 'spots'}
      </p>
    )}
  </div>
</a>
