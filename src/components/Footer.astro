---
import Logo from './Logo.astro';
import { CATEGORIES, CATEGORY_META } from '../content/config';
---
<footer class="mt-20 bg-mountain-900 text-sand-100">
  <div class="container-page py-14">
    <div class="grid gap-10 lg:grid-cols-[1.2fr_2fr_1fr]">
      <div class="space-y-4">
        <Logo variant="light" />
        <p class="max-w-sm text-sm leading-relaxed text-sand-200/80">
          A locally curated guide for vacation rental guests visiting Colorado Springs. Trails, tables,
          and treasures — picked by people who live here.
        </p>
        <a
          href="https://www.nestago.com"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 rounded-full border border-sand-200/30 bg-mountain-800/60 px-4 py-2 text-xs font-semibold text-sand-100 transition hover:border-clay-300 hover:text-clay-200"
        >
          <span aria-hidden="true">★</span>
          <span>Curated by Nestago — your Colorado Springs vacation rental host</span>
        </a>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-clay-300">Browse</p>
        <div class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2 sm:grid-cols-3">
          {CATEGORIES.map((slug) => (
            <a
              href={`/categories/${slug}`}
              class="text-sm text-sand-200/80 transition hover:text-clay-300"
            >
              {CATEGORY_META[slug].title}
            </a>
          ))}
        </div>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-clay-300">Visit</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href="/map" class="text-sand-200/80 transition hover:text-clay-300">Map of all places</a>
          </li>
          <li>
            <a href="/stay" class="text-sand-200/80 transition hover:text-clay-300">Where to stay</a>
          </li>
          <li>
            <a
              href="https://www.nestago.com"
              target="_blank"
              rel="noopener"
              class="text-sand-200/80 transition hover:text-clay-300"
            >
              Nestago rentals ↗
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
  <div class="border-t border-mountain-800">
    <div class="container-page flex flex-col items-center justify-between gap-3 py-6 text-xs text-sand-200/60 sm:flex-row">
      <p>&copy; {new Date().getFullYear()} ExploreCOS. Made in Colorado Springs.</p>
      <p>
        <a href="https://explorecos.com" class="hover:text-clay-300">explorecos.com</a>
      </p>
    </div>
  </div>
</footer>
