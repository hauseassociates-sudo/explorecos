---
import type { CollectionEntry } from 'astro:content';
import { CATEGORY_META } from '../content/config';

interface Props {
  entry: CollectionEntry<'listings'>;
}
const { entry } = Astro.props;
const { name, category, address, description, photos, priceRange, lloydsPick } = entry.data;
const cover = photos[0] ?? null;
const catMeta = CATEGORY_META[category];
---
<a
  href={`/listings/${entry.slug}`}
  class="group flex flex-col overflow-hidden rounded-2xl border border-mountain-100 bg-white shadow-card transition hover:-translate-y-0.5 hover:shadow-card-hover"
>
  <div class="relative aspect-[4/3] w-full overflow-hidden bg-sand-100">
    {cover ? (
      <img
        src={cover}
        alt={name}
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-4xl">
        {catMeta.emoji}
      </div>
    )}
    <span class="absolute left-3 top-3 chip bg-white/90 backdrop-blur">
      <span>{catMeta.emoji}</span>
      <span>{catMeta.title}</span>
    </span>
    {lloydsPick && (
      <span class="absolute right-3 top-3 inline-flex items-center gap-1 rounded-full bg-clay-500 px-2.5 py-1 text-xs font-semibold text-white shadow-sm">
        <span aria-hidden="true">⭐</span>
        <span>Lloyd's Pick</span>
      </span>
    )}
  </div>
  <div class="flex flex-1 flex-col gap-2 p-5">
    <div class="flex items-start justify-between gap-3">
      <h3 class="font-display text-lg font-semibold leading-tight text-mountain-900 group-hover:text-forest-700">
        {name}
      </h3>
      {priceRange && (
        <span class="shrink-0 text-sm font-medium text-mountain-500">{priceRange}</span>
      )}
    </div>
    <p class="text-xs text-mountain-500">{address}</p>
    <p class="line-clamp-2 text-sm text-mountain-700">{description}</p>
  </div>
</a>
